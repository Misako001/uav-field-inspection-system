APP_NAME=大田无人机巡检监控系统
APP_ENV=development
DATABASE_URL=sqlite:///./uav_inspection.db

# MySQL reserved configuration. Switch DATABASE_URL to this value when MySQL is ready.
MYSQL_DATABASE_URL=mysql+pymysql://uav_user:uav_password@127.0.0.1:3306/uav_inspection

RTMP_URL=rtmp://127.0.0.1/live/uav-field
HLS_URL=http://127.0.0.1:8080/hls/uav-field.m3u8
API_REFRESH_INTERVAL_SECONDS=2
MODEL_BACKEND=ckpt
MODEL_TYPE=deeplabv3plus_resnet34
MODEL_PATH=C:/Users/sylf2/xwechat_files/wxid_4f0alj4ijwed22_ebd4/msg/file/2026-04/best.ckpt
MODEL_DEVICE=auto
MODEL_CLASS_INDEX_CROP=1
MODEL_CLASS_INDEX_WEED=2
MODEL_ALLOW_MOCK_FALLBACK=true
IMAGE_RESULT_THRESHOLD=0.52
WEED_MIN_COMPONENT_AREA=20
WEED_MAX_COMPONENT_ASPECT_RATIO=5.5
WEED_MIN_COMPONENT_FILL_RATIO=0.16
WEED_CROP_EDGE_KERNEL_SIZE=9
WEED_CROP_EDGE_OVERLAP_RATIO=0.62
VIDEO_SAMPLE_FPS=1.5
STREAM_SAMPLE_INTERVAL_SECONDS=2.0
MAX_CONCURRENT_ANALYSIS_JOBS=2
STORAGE_ROOT=storage
