<UserControl x:Class="UAVInspectionDesktop.Views.RiskPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Border Style="{StaticResource PanelCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="*" />
                <RowDefinition Height="70" />
            </Grid.RowDefinitions>

            <Grid>
                <TextBlock Text="风险指数" Style="{StaticResource SectionTitleTextStyle}" />
                <Border HorizontalAlignment="Right" Background="#17382A" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1" CornerRadius="6" Padding="10,5">
                    <TextBlock Text="{Binding RiskLevel}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}" />
                </Border>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding DetectionStatistics.RiskIndex, StringFormat={}{0:F0}}" Style="{StaticResource MetricValueTextStyle}" FontSize="58" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding RiskDescription}" Style="{StaticResource BodyTextStyle}" TextAlignment="Center" Margin="16,12,16,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="风险构成：虫害疑似 41% · 病害疑似 35% · 视频异常 24%" Style="{StaticResource CaptionTextStyle}" />
                <Grid Grid.Row="1">
                    <Border Height="8" Background="#1A2A39" CornerRadius="4" VerticalAlignment="Center" />
                    <Border Width="{Binding RiskProgressWidth}" Height="8" Background="{StaticResource WarningBrush}" CornerRadius="4" HorizontalAlignment="Left" VerticalAlignment="Center" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
