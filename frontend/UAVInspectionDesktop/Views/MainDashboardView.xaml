<UserControl x:Class="UAVInspectionDesktop.Views.MainDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:UAVInspectionDesktop.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="*" />
            <RowDefinition Height="216" />
        </Grid.RowDefinitions>

        <local:HeaderBarView Grid.Row="0" />

        <Grid Grid.Row="1" Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.15*" />
                <ColumnDefinition Width="1.05*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <local:VideoPanelView Grid.Column="0" Margin="0,0,16,0" />

            <Grid Grid.Column="1" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="188" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="196" />
                </Grid.RowDefinitions>

                <local:StatisticsPanelView Grid.Row="0" />
                <local:RiskPanelView Grid.Row="1" Margin="0,16" />
                <local:ControlPanelView Grid.Row="2" />
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="192" />
                </Grid.RowDefinitions>

                <local:QuickAccessPanelView Grid.Row="0" />
                <local:StreamDetailView Grid.Row="1" Margin="0,16,0,0" />
            </Grid>
        </Grid>

        <local:AlertTimelineView Grid.Row="2" />
    </Grid>
</UserControl>
